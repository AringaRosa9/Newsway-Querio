# =============================================================================
# AI News Search — Environment Configuration
# Copy this file to .env and fill in your values.
# =============================================================================

# ---------------------------------------------------------------------------
# App
# ---------------------------------------------------------------------------
APP_NAME=AI News Search
LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# Elasticsearch
# ---------------------------------------------------------------------------
ES_URL=http://localhost:9200
ES_INDEX=news_articles

# ---------------------------------------------------------------------------
# Qdrant (vector database)
# ---------------------------------------------------------------------------
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=news_vectors

# ---------------------------------------------------------------------------
# Redis (caching / task queue)
# ---------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# ---------------------------------------------------------------------------
# AI / LLM
# ---------------------------------------------------------------------------
# Get your key at https://console.anthropic.com/
ANTHROPIC_API_KEY=your-api-key-here

# Sentence-transformer model used for dense embeddings.
# BAAI/bge-m3 supports both Chinese and English.
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIM=1024

# ---------------------------------------------------------------------------
# Authentication
# ---------------------------------------------------------------------------
# Secret key for JWT token signing. MUST be changed in production.
JWT_SECRET=change-me-in-production-use-a-real-secret

# ---------------------------------------------------------------------------
# Social Media APIs
# ---------------------------------------------------------------------------
# Twitter API v2 bearer token (optional — social monitoring)
TWITTER_BEARER_TOKEN=
# Weibo API access token (optional — social monitoring)
WEIBO_ACCESS_TOKEN=

# ---------------------------------------------------------------------------
# Email (subscription notifications)
# ---------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@ainews.local

# ---------------------------------------------------------------------------
# Ingestion
# ---------------------------------------------------------------------------
# How often (in seconds) to re-fetch RSS feeds. Default: 900 s (15 min).
RSS_FETCH_INTERVAL=900

# ---------------------------------------------------------------------------
# Search
# ---------------------------------------------------------------------------
# Maximum number of hits returned by a single search request.
MAX_SEARCH_RESULTS=50

# Maximum number of documents fed to the AI summariser per query.
SUMMARY_MAX_DOCS=10
